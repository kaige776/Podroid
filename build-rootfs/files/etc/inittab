::sysinit:/sbin/openrc sysinit
::sysinit:/sbin/openrc boot
::wait:/sbin/openrc default

# Two gettys are declared, but only one starts per boot — see /usr/local/bin/podroid-getty:
# the wrapper reads `podroid.tty=` from the kernel cmdline and sleeps the wrong tty
# instead of running getty there. This keeps the squashfs backend-agnostic.
hvc0::respawn:/usr/local/bin/podroid-getty hvc0
ttyS0::respawn:/usr/local/bin/podroid-getty ttyS0
::shutdown:/sbin/openrc shutdown
