#!/bin/sh
# Replacement login shell for getty. Restores the terminal size from
# /run/term_size (written by podroid-resize on QEMU) before exec'ing the
# real login binary — virtio-console + PL011 serial both reset winsize
# to 0x0 on every getty respawn, so without this TUI apps (btop, htop,
# vim, less) bail with "Failed to get size of terminal".
#
# AVF doesn't run podroid-resize for ttyS0 (no SIGWINCH propagation
# channel yet), so /run/term_size won't exist there — fall back to a
# sensible default rather than leaving winsize at 0x0. The host-side
# TerminalView will overwrite this the moment the user touches the
# screen and triggers a real SIGWINCH.
if [ -r /run/term_size ]; then
    read _r _c < /run/term_size
fi
[ -z "$_r" ] && _r=24
[ -z "$_c" ] && _c=80
stty rows "$_r" cols "$_c" 2>/dev/null
exec /bin/login "$@"
